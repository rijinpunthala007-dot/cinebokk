# CineBook Environment Variables — copy to .env and fill in values.
# On Render, set these in the service's Environment tab (NOT committed to git).

# --- Django Core ---
# Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True
# Comma-separated. Render's own hostname is trusted automatically via
# RENDER_EXTERNAL_HOSTNAME, so you usually don't need to add it here.
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database ---------------------------------------------------------------
# Resolution order in settings.py:
#   1. DATABASE_URL set        -> used verbatim (Render Postgres in production)
#   2. USE_POSTGRES=True       -> discrete Postgres vars below
#   3. USE_MYSQL=True          -> discrete MySQL vars below (local dev)
#   4. none of the above       -> SQLite (zero-config local dev)
#
# PRODUCTION (Render): set DATABASE_URL to the Internal Database URL Render gives
# you when you create a PostgreSQL instance. Leave the flags below False.
# DATABASE_URL=postgres://user:password@host:5432/dbname
# DB_SSL_REQUIRE=True          # managed Postgres requires SSL (default True)
# DB_CONN_MAX_AGE=600          # persistent connection lifetime (seconds)

# LOCAL DEV — MySQL (set USE_MYSQL=True to use these):
USE_MYSQL=False
# LOCAL DEV — Postgres without a URL (set USE_POSTGRES=True to use these):
USE_POSTGRES=False
DB_NAME=cinebook_db
DB_USER=root
DB_PASSWORD=your-db-password
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Static / Media ---------------------------------------------------------
STATIC_URL=/static/
MEDIA_URL=/media/
# Cache lifetime (seconds) for static assets served by WhiteNoise. 1 year is safe
# because manifest storage fingerprints filenames.
WHITENOISE_MAX_AGE=31536000

# --- Security (production) --------------------------------------------------
# Force HTTPS redirects when DEBUG=False. Keep True on Render.
SECURE_SSL_REDIRECT=True

# --- Seat Lock Settings ---
# How many minutes a seat hold lasts before it expires
SEAT_LOCK_MINUTES=5

# --- Showtime Refresh Cron -----------------------------------------------
# Shared secret for POST /api/v1/internal/refresh-showtimes/, which an
# external free cron service (e.g. cron-job.org) pings daily since Render's
# free tier has no persistent process for django-crontab. Must match EXACTLY
# what you configure in the cron service (as an X-Cron-Secret header or a
# ?token= query param) — set this in Render's environment variables too.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
CRON_SECRET=your-long-random-cron-secret-here

# --- CORS / CSRF ------------------------------------------------------------
# Comma-separated allowed origins (no trailing slash).
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Any *.onrender.com origin is allowed by default via a regex in settings.py.
# CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.onrender\.com$
# CSRF trusted origins for HTTPS POST/PUT/DELETE. Defaults to https://*.onrender.com.
# Replace with your exact service URL once known:
# CSRF_TRUSTED_ORIGINS=https://cinebook.onrender.com

# --- JWT ---
# Access token lifetime in minutes
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
# Refresh token lifetime in days
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Rate Limiting ---
ANON_THROTTLE_RATE=120/min
USER_THROTTLE_RATE=300/min
MOVIES_READ_THROTTLE_RATE=300/min
